{
  "reconciliation_scenarios": [
    {
      "id": "scenario_01_metformin_dose_conflict",
      "description": "Diabetic patient with declining kidney function. Three sources disagree on Metformin dose. Tests renal dosing adjustment logic.",
      "request": {
        "patient_context": {
          "age": 67,
          "conditions": ["Type 2 Diabetes", "Hypertension", "Chronic Kidney Disease Stage 3"],
          "recent_labs": {"eGFR": 45, "hba1c": 7.2, "creatinine": 1.8}
        },
        "sources": [
          {
            "system": "Hospital EHR",
            "medication": "Metformin 1000mg twice daily",
            "last_updated": "2024-10-15",
            "source_reliability": "high"
          },
          {
            "system": "Primary Care",
            "medication": "Metformin 500mg twice daily",
            "last_updated": "2025-01-20",
            "source_reliability": "high"
          },
          {
            "system": "Pharmacy",
            "medication": "Metformin 1000mg daily",
            "last_filled": "2025-01-25",
            "source_reliability": "medium"
          }
        ]
      },
      "expected_reconciled": "Metformin 500mg twice daily",
      "expected_reasoning_contains": ["kidney", "eGFR", "dose reduction"]
    },
